# Required: Copy this file to .env and fill in all values.
#
#   cp .env.example .env

# --- Database ---
POSTGRES_USER=bouncr
POSTGRES_PASSWORD=          # strong random password

# --- Shared secrets (must be identical between api-server and proxy) ---
JWT_SECRET=                 # 32+ character random string
INTERNAL_SIGNING_KEY=       # random string for internal API authentication

# --- API server ---
ADMIN_PASSWORD=             # initial admin user password (used only on first startup)
CORS_ORIGINS=               # allowed origins, e.g. https://your-domain.com
OIDC_KEY_ENCRYPTION_KEY=    # (optional) 32-byte Base64 AES-256 key for private key encryption at rest

# --- Proxy ---
LOG_LEVEL=info              # debug, info, warn, error

# --- Ports exposed to host ---
LISTEN_PORT=3000            # Envoy reverse proxy port
UI_PORT=8080                # UI port
